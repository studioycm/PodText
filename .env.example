APP_KEY=

# Mail: local default writes messages to storage/logs/laravel.log.
MAIL_MAILER=log
MAIL_FROM_ADDRESS=hello@podtext.co.il
MAIL_FROM_NAME="${APP_NAME}"

# Mail option A, recommended for production: Resend API transport.
# Set MAIL_MAILER=resend and RESEND_KEY after verifying the sending domain.
RESEND_KEY=

# Mail option B, zero-package/provider-generic SMTP fallback.
# Resend SMTP: MAIL_HOST=smtp.resend.com, MAIL_USERNAME=resend, MAIL_PASSWORD=API key.
# Brevo SMTP: use Brevo's SMTP host, login, and SMTP key from the account console.
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=

# Public forms email OTP policy.
FORMS_OTP_EXPIRES_MINUTES=5
FORMS_OTP_MAX_ATTEMPTS=5
FORMS_OTP_RESEND_COOLDOWN_SECONDS=60

# Optional. If unset, Curator Glide falls back to APP_KEY for signed media URLs.
CURATOR_GLIDE_TOKEN=

# Optional. Enables local Public Content Settings page profiling logs.
SETTINGS_PROFILING=false

# Optional. Leave disabled locally; enable in production when persistent Spatie settings caching is desired.
SETTINGS_CACHE_ENABLED=false
SETTINGS_CACHE_MEMO=false
