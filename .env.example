APP_KEY=

# Optional. If unset, Curator Glide falls back to APP_KEY for signed media URLs.
CURATOR_GLIDE_TOKEN=

# Optional. Enables local Public Content Settings page profiling logs.
SETTINGS_PROFILING=false

# Optional. Leave disabled locally; enable in production when persistent Spatie settings caching is desired.
SETTINGS_CACHE_ENABLED=false
SETTINGS_CACHE_MEMO=false
